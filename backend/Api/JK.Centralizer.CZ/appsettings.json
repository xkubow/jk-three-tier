{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "PolicyName": "DefaultCorsPolicy",
    "AllowedOrigins": [ "http://localhost:8080", "http://localhost:8095" ],
    "AllowedMethods": [ "*" ],
    "AllowedHeaders": [ "*" ],
    "AllowCredentials": false
  },
  "AllowedHosts": "*",
  "ConfigurationProvider": {
    "ServerUrl": "https://localhost:7001"
  },
  "GrpcClientConfiguration": {
    "UseSecureSslChannel": true
  },
  "GrpcClients": {
    "OrderService": {
      "Url": "https://localhost:7002"
    }
  },
  "Platform": {
    "MarketCode": "CZ",
    "ServiceCode": "JK.Centralizer.CZ"
  }
}
