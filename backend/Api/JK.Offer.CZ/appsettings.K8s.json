{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres-postgresql.infra.svc.cluster.local;Port=5432;Database=jk_offer;Username=postgres;Password=change-me-strong-password"
  },
  "Database": {
    "RunMigrationsOnStartup": true
  },
  "Cors": {
    "PolicyName": "DefaultCorsPolicy",
    "AllowedOrigins": [ "*" ],
    "AllowedMethods": [ "*" ],
    "AllowedHeaders": [ "*" ],
    "AllowCredentials": false
  },
  "AllowedHosts": "*",
  "ConfigurationProvider": {
    "ServerUrl": "http://jk-configuration-cz.jk-platform-cz.svc.cluster.local:8080"
  },
  "GrpcClientConfiguration": {
    "UseSecureSslChannel": false
  },
  "Platform": {
    "MarketCode": "CZ",
    "ServiceCode": "JK.Offer.CZ"
  }
}
